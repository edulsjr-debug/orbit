# Banco de dados (Railway PostgreSQL ou local)
DATABASE_URL="postgresql://user:password@localhost:5432/orbit"

# JWT
JWT_SECRET="troque-por-uma-string-aleatoria-longa"
SALT="troque-por-outro-salt"

# URL do frontend
WEB_URL="http://localhost:3000"

# Push Notifications (Web Push API)
# Gerar com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_EMAIL="admin@orbit.app"

# Email (Resend — https://resend.com)
RESEND_API_KEY=""
EMAIL_FROM="Orbit <noreply@orbit.app>"

# Redis (para fila de notificações — Railway Redis ou local)
REDIS_URL="redis://localhost:6379"
