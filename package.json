{
  "name": "orbit",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "db:generate": "pnpm --filter @orbit/database generate",
    "db:migrate": "pnpm --filter @orbit/database migrate:dev",
    "db:studio": "pnpm --filter @orbit/database studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
